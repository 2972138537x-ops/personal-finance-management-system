<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.usermanagement.mapper.UserMapper">

    <select id="findByUsername" resultType="com.study.usermanagement.entity.User">
        SELECT username, password, role, token
        FROM `user`
        WHERE username = #{username}
    </select>

    <select id="findByToken" resultType="com.study.usermanagement.entity.User">
        SELECT username, password, role, token
        FROM `user`
        WHERE token = #{token}
    </select>

    <select id="findAll" resultType="com.study.usermanagement.entity.User">
        SELECT username, password, role, token
        FROM `user`
    </select>

    <insert id="insert">
        INSERT INTO `user`(username, password, role, register_date)
        VALUES(#{username}, #{password}, 'USER', CURDATE())
    </insert>

    <update id="updatePassword">
        UPDATE `user`
        SET password = #{password}
        WHERE username = #{username}
    </update>

    <delete id="deleteByUsername">
        DELETE FROM `user`
        WHERE username = #{username}
    </delete>

    <update id="updateToken">
        UPDATE `user`
        SET token = #{token}
        WHERE username = #{username}
    </update>

    <update id="clearToken">
        UPDATE `user`
        SET token = NULL
        WHERE username = #{username}
    </update>

</mapper>
